GQL_HOST=https://wordpress-sismooni.liara.run/graphql
NUXT_PUBLIC_WP_BASE_URL=https://wordpress-sismooni.liara.run
NUXT_PUBLIC_SITE_URL=http://localhost:3001
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
NUXT_PUBLIC_ZARINPAL_PAYMENT_METHOD=WC_ZPal
# Backend served with a non-publicly-trusted CA (e.g. Liara). Set to true so the
# Nuxt server can reach WordPress over HTTPS. Prefer a trusted cert in production.
WP_INSECURE_TLS=true
